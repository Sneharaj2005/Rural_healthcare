# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Local dev:
MONGODB_URL=mongodb://localhost:27017
# Atlas (production):
# MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=rural_health_companion
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=1

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_long_random_secret_key_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Get free key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Google Maps / Places ──────────────────────────────────────────────────────
# Enable: Maps JavaScript API + Places API at https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
PLACES_SEARCH_RADIUS_M=5000

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=text              # text (dev) | json (prod)

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Gmail: enable 2FA → create App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM_NAME=RHC AI Lite
SMTP_FROM_EMAIL=your_email@gmail.com
EMAIL_ENABLED=false

# ── Notification scheduler ────────────────────────────────────────────────────
REMINDER_DAYS_BEFORE=7
SCHEDULER_HOUR=8
SCHEDULER_MINUTE=0
